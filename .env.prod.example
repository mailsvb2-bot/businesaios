# BusinesAIOS production environment contract
# Copy to deployment secrets manager or server environment. Never commit real secrets.
APP_ENV=prod
ENV=prod
LOG_LEVEL=INFO
TENANT_ID=replace-with-tenant-id
BUSINESAIOS_DATA_DIR=/var/lib/businesaios/runtime

APP_PROFILE=api
RUN_MODE=telegram
API_HOST=0.0.0.0
API_PORT=8000
HEALTH_HOST=127.0.0.1
TELEGRAM_HEALTH_PORT=8088
EVOLUTION_HEALTH_PORT=8087
EVOLUTION_ENABLED=1

# Production storage must be PostgreSQL or an equivalent durable backend.
METRO_DB_ENGINE=postgres
DATABASE_URL=postgresql://user:password@host:5432/database
POSTGRES_DSN=postgresql://user:password@host:5432/database

TELEGRAM_BOT_TOKEN=
TELEGRAM_USE_WEBHOOK=1
TELEGRAM_WEBHOOK_ENABLED=1
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=https://example.com/telegram/webhook
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_HOST=0.0.0.0
TELEGRAM_WEBHOOK_PORT=8080
TELEGRAM_WEBHOOK_AUTO_REGISTER=1
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=0
TELEGRAM_WEBHOOK_MAX_CONNECTIONS=40
TELEGRAM_WEBHOOK_ALLOWED_UPDATES=message,callback_query

CONTROL_PLANE_API_KEY=

# Production must not use sqlite-backed secret or key providers.
BUSINESAIOS_SECRET_VAULT_BACKEND=external
BUSINESAIOS_KEY_PROVIDER_BACKEND=external

API_DOCS_ENABLED=0
BUSINESAIOS_API_IDEMPOTENCY_PATH=/var/lib/businesaios/runtime/api/api_idempotency.sqlite3
