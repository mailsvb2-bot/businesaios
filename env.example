# =========================================================
# businesaios — PRODUCTION ENV (2-PROCESS MODE)
# =========================================================
# Process 1: Telegram Runtime   (RUN_MODE=telegram)
# Process 2: Evolution Worker   (RUN_MODE=evolution)
# =========================================================


# =========================================================
# CORE / GLOBAL
# =========================================================

ENV=prod
LOG_LEVEL=INFO
PRINT_EVENTS=0

# Recommended for clean release archives (avoid __pycache__/ and *.pyc)
PYTHONDONTWRITEBYTECODE=1

# Optional tenant id for multi-tenant event store.
TENANT_ID=default

# =========================================================
# QUICK MODES
# =========================================================
# SAFE DEV MODE (recommended while wiring UX / transports)
#   - Retention OFF (no offers / no marketing pressure)
#   - Bandit OFF (no learning noise)
#
#   RETENTION_ENABLED=0
#   MARKETING_BANDIT_ENABLED=0
#   AUTOPRICING_ENABLED=0
#   OFFER_OUTCOME_EMIT_ENABLED=0
#
# PRODUCTION MODE (full AI loop)
#   - Retention ON (offers/hazard/readiness)
#   - Bandit ON (variant learning)
#   - Autopricing ON (price suggestions)
#   - Offer outcome emitter ON (learn from timeouts/fails)
#
#   RETENTION_ENABLED=1
#   MARKETING_BANDIT_ENABLED=1
#   AUTOPRICING_ENABLED=1
#   OFFER_OUTCOME_EMIT_ENABLED=1

# RETENTION / MARKETING (SAFE BY DEFAULT)
# 0 = disabled, 1 = enabled
RETENTION_ENABLED=0

########################################
# FEATURE FLAGS (SAFE BY DEFAULT)
########################################
SCHEDULED_OUTBOX_ENABLED=0
ASYNC_TELEGRAM_ENABLED=0
LLM_MARKETING_ENABLED=0
MARKETING_BANDIT_ENABLED=0

# =========================================================
# LLM (OPTIONAL, SAFE BY DEFAULT)
# =========================================================
# Canonical switch:
LLM_ENABLED=0
# Backward-compatible alias (deprecated): LLM_MARKETING_ENABLED

# Provider wiring (openai-compatible Responses API)
LLM_PROVIDER=openai_compat
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
# API key (required when LLM_ENABLED=1)
LLM_API_KEY=

# Rate limits / budgets (optional)
LLM_GLOBAL_RPS=15
LLM_GLOBAL_BURST=20
LLM_TENANT_RPS=4
LLM_TENANT_BURST=6
LLM_BUDGET_SOURCE=auto

# =========================================================
# ADS GUARDRAILS (SAFE DEFAULTS)
# =========================================================
ADS_DRY_RUN=1
ADS_PLAN_ONLY=1
ADS_APPLY_ENABLED=0
ADS_MAX_DAILY_BUDGET=0
# comma-separated: yandex,meta,tg,vk
ADS_ALLOWED_PLATFORMS=

# Optional OpenAI headers (ignored by other providers)
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# =========================================================
# PRICING / LEARNING JOBS
# =========================================================

# Enable price optimizer overlays in tariff UX (0/1)
AUTOPRICING_ENABLED=0

# Emit offer_outcome events automatically (0/1)
OFFER_OUTCOME_EMIT_ENABLED=1

# Max offers per user per day (0 disables cap)
OFFER_DAILY_CAP=2


# =========================================================
# BEHAVIOR GRAPH (OPTIONAL)
# =========================================================
# Only used when STORAGE_BACKEND=sqlite (dev/single-node).
# Default path: $DATA_DIR/behavior_graph.db
BEHAVIOR_GRAPH_SQLITE_PATH=

# Retention sandbox rollout (safe-by-default).
# When RETENTION_SANDBOX=1, offers will be shown ONLY to users from RETENTION_SANDBOX_USER_IDS.
RETENTION_SANDBOX=0
RETENTION_SANDBOX_USER_IDS=

# Admin ids (comma-separated Telegram chat/user ids)
# Backward compatible alias: ADMIN_IDS
ADMIN_USER_IDS=

# IMPORTANT:
# Telegram runtime must use RUN_MODE=telegram
# Evolution worker must use RUN_MODE=evolution
# (set per process, not here globally if using docker-compose)


# =========================================================
# TELEGRAM RUNTIME
# =========================================================

# Telegram bot token
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# =========================================================
# ENGINE SELECTORS (PRODUCT + ACTIVE POLICY)
# =========================================================
# Pick which product runs on top of the Engine.
# Available configs in /products:
#   - product_example.yaml  (example connected product)
#   - sales.yaml
#   - retention.yaml
#   - org_platform.yaml  (default autopilot workspace)
PRODUCT_CONFIG=product_example.yaml

# Deterministic active policy selection during bootstrap.
# Default is the unified Telegram UX policy.
BOOT_ACTIVE_POLICY_ID=telegram_policy@v3

# Optional: strict production mode (recommended = 1)
# If set to 0/false/no — disables strict entrypoint/run-mode enforcement in prod.
PRODUCTION_STRICT_MODE=1

# Optional: webhook disabled (we use long polling)
TELEGRAM_USE_WEBHOOK=0

# Optional: health endpoint for telegram process (0 = disabled)
TELEGRAM_HEALTH_PORT=0

# Ingress safety: update dedupe TTL + per-chat rate limit
TG_UPDATE_DEDUP_TTL_S=120
TG_RATE_BURST=10
TG_RATE_REFILL_PER_S=2

# Optional: bot username (without @).
# If omitted, telegram runtime will try to fill BOT_USERNAME from getMe() on first poll.
BOT_USERNAME=
# Optional: public username override (without @)
PUBLIC_BOT_USERNAME=

# Outbound Telegram rate limit + queue (recommended defaults)
TG_OUTBOUND_GLOBAL_RPS=25.0
TG_OUTBOUND_GLOBAL_BURST=30
TG_OUTBOUND_CHAT_RPS=1.0
TG_OUTBOUND_CHAT_BURST=3
TG_OUTBOUND_QUEUE_MAX=1000
TG_OUTBOUND_WARN_QUEUE=200

# =========================================================
# OUTBOUND OBSERVABILITY (ALERT-ONLY, NO SPAM)
# =========================================================
# These produce log lines ONLY when something is wrong, throttled by MIN_INTERVAL.
# If all are disabled -> zero extra logs.

# Alert if UX queue-wait p95 exceeds X ms (0 disables)
OUTBOUND_ALERT_UX_P95_WAIT_MS=0

# Alert if best-effort drops happened (recommended = 1)
OUTBOUND_ALERT_DROP_BEST_EFFORT=1

# Alert if outbound queue size exceeds threshold (0 disables)
OUTBOUND_ALERT_QSIZE=0

# Anti-spam: minimum seconds between alert lines (recommended 60–300)
OUTBOUND_ALERT_MIN_INTERVAL_S=60

# =========================================================
# OUTBOUND SELF-HEAL (TRANSPORT LEVEL)
# =========================================================
# When enabled, if alerts fire, marketing is temporarily suppressed
# so UX gets stable latency under spikes.

OUTBOUND_SELF_HEAL_ENABLED=0

# How long to suppress marketing (seconds)
OUTBOUND_SELF_HEAL_MARKETING_COOLDOWN_S=60

# Which alert reasons trigger self-heal
OUTBOUND_SELF_HEAL_ON_SLA=1
OUTBOUND_SELF_HEAL_ON_QSIZE=1
OUTBOUND_SELF_HEAL_ON_DROPS=0
# =========================================================
# OUTBOUND PURGE (BACKLOG SHEDDING)
# =========================================================
# Purge removes ONLY best-effort tasks (critical=0) whose kind is in BLACKLIST
# and not in WHITELIST, when self-heal triggers.

OUTBOUND_PURGE_ENABLED=1
OUTBOUND_PURGE_MAX_ITEMS=10000

# Comma-separated lists (case-insensitive)
OUTBOUND_PURGE_BLACKLIST=marketing,bulk,analytics
OUTBOUND_PURGE_WHITELIST=ux,system,payments



# Optional: legacy pacing (only used if outbound queue is disabled)
TELEGRAM_MIN_MSG_INTERVAL_S=


# =========================================================
# DATABASE / STORAGE
# =========================================================

# If using SQLite (default FAST/PROD behavior)
# Path must be shared between telegram + evolution
SQLITE_DB_PATH=data/businesaios.db

# If using Postgres instead (comment SQLite if enabled)
# DATABASE_URL=postgresql://user:password@host:5432/businesaios_db


# =========================================================
# PAYMENTS (YooKassa example)
# =========================================================

PAYMENT_PROVIDER=yookassa

YOOKASSA_SHOP_ID=YOUR_SHOP_ID
YOOKASSA_SECRET_KEY=YOUR_SECRET_KEY

# Optional staging flag
PAYMENT_ENV=prod


# =========================================================
# MARKETING / VARIANTS
# =========================================================

# Enable marketing A/B logic
MARKETING_ENABLED=1

# Variant selection strategy: random | epsilon_greedy | thompson
MARKETING_STRATEGY=epsilon_greedy

# Exploration rate (if epsilon_greedy)
MARKETING_EPSILON=0.1


# =========================================================
# EVOLUTION WORKER SETTINGS
# =========================================================
# Only used when RUN_MODE=evolution

EVOLUTION_POLL_INTERVAL_SEC=2
EVOLUTION_BATCH_SIZE=10
EVOLUTION_HEALTH_PORT=8087

# Safety cap for heavy tasks
EVOLUTION_MAX_RUNTIME_SEC=60


# =========================================================
# SECURITY / GUARD LAYER
# =========================================================

# DecisionCore signing secret (REQUIRED in prod; use a strong random value).
# For local dev, set DECISIONCORE_SECRET_ALLOW_DEV_DEFAULT=1 to use built-in default.
DECISIONCORE_SECRET=
# DECISIONCORE_SECRET_ALLOW_DEV_DEFAULT=1  # Uncomment for local dev only

# Enforce runtime allowlist strictly
GUARD_STRICT_MODE=1

# Optional admin list (comma-separated Telegram IDs)
# Code accepts both ADMIN_IDS and ADMIN_USER_IDS.
ADMIN_USER_IDS=123456789,987654321
# ADMIN_IDS=123456789,987654321

# Governance: allow the same admin to approve their own pricing request.
# Default: 0 (forbid self-approval; recommended).
ALLOW_SELF_APPROVE=0


# =========================================================
# PERFORMANCE / READ MODEL
# =========================================================

# Enable incremental counters (if implemented)
READ_MODEL_INCREMENTAL=1

# Cache window for expensive recomputations
READ_MODEL_CACHE_WINDOW_SEC=5

# SLA budget (ms) for the whole button pipeline
SLA_BUTTON_BUDGET_MS=300


# =========================================================
# PRICING VERSIONING (STRICT PROD)
# =========================================================
# In strict prod, bot refuses to start if:
# - PRICING_VERSION is missing
# - PRICING_VERSION looks like a default placeholder (v1, v0*, default)
# - pricing fingerprint changed but PRICING_VERSION did not change
PRICING_VERSION=v17.0
PRICING_FINGERPRINT_PATH=data/pricing_fingerprint.json

# Button SLA budget used for perf spans.
# (Same variable as in PERFORMANCE / READ MODEL section above.)

# Survival controller log rate-limit (prevents log spam under load)
SURVIVAL_LOG_EVERY_SEC=60


# =========================================================
# GIFTS
# =========================================================

# Gift link TTL in seconds (default: 7 days)
GIFT_TTL_SEC=604800

# Print full events in demo/runtime (off by default)
PRINT_EVENTS=0


# =========================================================
# PRICING
# =========================================================

CURRENCY=RUB
DEFAULT_PRICE_RUB=4900


# =========================================================
# SELF-DRIVING / AI ECONOMY FLAGS
# =========================================================

# Enable evolution jobs at all
EVOLUTION_ENABLED=1

# Allow automated price experiments
PRICE_EXPERIMENTS_ENABLED=0

# Safety: require admin approval for price changes
PRICE_CHANGE_REQUIRES_APPROVAL=1


# Telegram audio pacing (seconds)
TELEGRAM_MIN_AUDIO_INTERVAL_S=0.7

# Outbound queue overflow policy: block | drop | degrade
TG_OUTBOUND_OVERFLOW_POLICY=block

# Retention anti-spam: max offers per user per day (0 disables)
OFFER_DAILY_CAP=2
