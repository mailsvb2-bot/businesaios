# BusinesAIOS default example: local/staging advisory profile.
# Do not use this file as a production environment file.
# For production, start from .env.example.prod and replace every placeholder secret/DSN.

APP_ENV=staging
ENV=staging
LOG_LEVEL=INFO
TENANT_ID=default-business
BUSINESAIOS_DATA_DIR=./runtime/data

APP_PROFILE=api
RUN_MODE=demo
API_HOST=127.0.0.1
API_PORT=8000
HEALTH_HOST=127.0.0.1
TELEGRAM_HEALTH_PORT=8088
EVOLUTION_HEALTH_PORT=8087
EVOLUTION_ENABLED=0

METRO_DB_ENGINE=sqlite
DATABASE_URL=
POSTGRES_DSN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_USE_WEBHOOK=0
TELEGRAM_WEBHOOK_ENABLED=0
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_HOST=127.0.0.1
TELEGRAM_WEBHOOK_PORT=8080
TELEGRAM_WEBHOOK_AUTO_REGISTER=0
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=0
TELEGRAM_WEBHOOK_MAX_CONNECTIONS=40
TELEGRAM_WEBHOOK_ALLOWED_UPDATES=message,callback_query
CONTROL_PLANE_API_KEY=

BUSINESAIOS_SECRET_VAULT_BACKEND=sqlite
BUSINESAIOS_KEY_PROVIDER_BACKEND=sqlite

API_DOCS_ENABLED=0
BUSINESAIOS_API_IDEMPOTENCY_PATH=./runtime/data/api/api_idempotency.sqlite3
