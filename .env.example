# Canonical server/container contract
APP_ENV=prod
ENV=prod
LOG_LEVEL=INFO
TENANT_ID=default-business
BUSINESAIOS_DATA_DIR=/var/lib/businesaios/runtime

# Profiles
APP_PROFILE=api
RUN_MODE=telegram
API_HOST=0.0.0.0
API_PORT=8000
HEALTH_HOST=127.0.0.1
TELEGRAM_HEALTH_PORT=8088
EVOLUTION_HEALTH_PORT=8087
EVOLUTION_ENABLED=1

# Storage (required in prod)
METRO_DB_ENGINE=postgres
DATABASE_URL=postgresql://businesaios:change-me@127.0.0.1:5432/businesaios
POSTGRES_DSN=postgresql://businesaios:change-me@127.0.0.1:5432/businesaios

# Secrets contract (never commit real values)
TELEGRAM_BOT_TOKEN=
TELEGRAM_USE_WEBHOOK=0
TELEGRAM_WEBHOOK_ENABLED=0
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_HOST=0.0.0.0
TELEGRAM_WEBHOOK_PORT=8080
TELEGRAM_WEBHOOK_AUTO_REGISTER=1
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=0
TELEGRAM_WEBHOOK_MAX_CONNECTIONS=40
TELEGRAM_WEBHOOK_ALLOWED_UPDATES=message,callback_query
CONTROL_PLANE_API_KEY=
# Required in prod: set a real high-entropy key before start
BUSINESAIOS_SECRET_VAULT_BACKEND=sqlite
BUSINESAIOS_KEY_PROVIDER_BACKEND=sqlite

# Optional API controls
API_DOCS_ENABLED=0
BUSINESAIOS_API_IDEMPOTENCY_PATH=/var/lib/businesaios/runtime/api/api_idempotency.sqlite3
