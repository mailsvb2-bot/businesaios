{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvaluationResult",
  "type": "object",
  "required": ["candidate_id", "metrics"],
  "properties": {
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    }
  },
  "additionalProperties": false
}
