# BusinesAIOS staging environment template.
# Staging may be advisory, but real staging runtime proof must use a real DATABASE_URL and container runtime.

APP_ENV=staging
ENV=staging
LOG_LEVEL=INFO
TENANT_ID=default-business
BUSINESAIOS_DATA_DIR=/var/lib/businesaios/runtime

APP_PROFILE=api
RUN_MODE=telegram
API_HOST=0.0.0.0
API_PORT=8000
HEALTH_HOST=127.0.0.1
TELEGRAM_HEALTH_PORT=8088
EVOLUTION_HEALTH_PORT=8087
EVOLUTION_ENABLED=1

METRO_DB_ENGINE=postgres
DATABASE_URL=REPLACE_WITH_STAGING_POSTGRES_DSN
POSTGRES_DSN=REPLACE_WITH_STAGING_POSTGRES_DSN

POSTGRES_LIVE_PROOF_REQUIRED=0
CONTAINER_RUNTIME_PROOF_REQUIRED=0
CONTAINER_RUNTIME_EVIDENCE_REQUIRED=0
REAL_RUNTIME_BOOT_EVIDENCE_REQUIRED=0
PRODUCTION_BOOT_PROOF_REQUIRED=0
STAGING_RUNTIME_PROOF_REQUIRED=0

TELEGRAM_BOT_TOKEN=REPLACE_WITH_STAGING_TELEGRAM_BOT_TOKEN
TELEGRAM_USE_WEBHOOK=1
TELEGRAM_WEBHOOK_ENABLED=1
TELEGRAM_WEBHOOK_SECRET=REPLACE_WITH_HIGH_ENTROPY_SECRET
TELEGRAM_WEBHOOK_URL=REPLACE_WITH_PUBLIC_STAGING_WEBHOOK_URL
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_HOST=0.0.0.0
TELEGRAM_WEBHOOK_PORT=8080
TELEGRAM_WEBHOOK_AUTO_REGISTER=1
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=0
TELEGRAM_WEBHOOK_MAX_CONNECTIONS=40
TELEGRAM_WEBHOOK_ALLOWED_UPDATES=message,callback_query

CONTROL_PLANE_API_KEY=REPLACE_WITH_STAGING_CONTROL_PLANE_KEY
BUSINESAIOS_SECRET_VAULT_BACKEND=sqlite
BUSINESAIOS_KEY_PROVIDER_BACKEND=sqlite

API_DOCS_ENABLED=0
BUSINESAIOS_API_IDEMPOTENCY_PATH=/var/lib/businesaios/runtime/api/api_idempotency.sqlite3
