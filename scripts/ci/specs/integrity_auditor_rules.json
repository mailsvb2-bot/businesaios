{
  "version": 2,
  "name": "BusinessAIOS Integrity Auditor",
  "goal": "Verify architectural integrity, DecisionCore singularity, canonical flow completeness, no-second-brain discipline, guarded execution, admin visibility, evidence, replay, config, and dead-capability risks.",
  "thresholds": {
    "fail_on_severity": [
      "P0"
    ],
    "warn_on_severity": [
      "P1",
      "P2"
    ],
    "minimum_architectural_integrity": 70,
    "minimum_decisioncore_integrity": 70,
    "minimum_flow_completeness": 60,
    "minimum_admin_surface_coverage": 50,
    "minimum_evidence_coverage": 40,
    "minimum_runtime_side_effect_safety": 60
  },
  "canonical_flow": [
    "signal",
    "state",
    "decision",
    "policy",
    "guard",
    "execution",
    "verification",
    "evidence",
    "archive"
  ],
  "decision_core_allowed_names": [
    "DecisionCore",
    "decision_core"
  ],
  "executable_decision_authority_names": [
    "DecisionCore",
    "DecisionCoreEngine",
    "DecisionEngine",
    "PlannerEngine"
  ],
  "second_brain_suspicious_terms": [
    "second_brain",
    "shadow_brain",
    "alternate_brain",
    "local_brain",
    "strategy_engine",
    "decision_engine",
    "planner_engine",
    "private_planner",
    "self_driving_brain",
    "autopilot_brain",
    "world_model_brain"
  ],
  "side_effect_calls": [
    "requests.post",
    "requests.put",
    "requests.patch",
    "requests.delete",
    "httpx.post",
    "httpx.put",
    "httpx.patch",
    "httpx.delete",
    "subprocess.run",
    "subprocess.Popen",
    "send_email",
    "capture_payment",
    "refund_payment",
    "bot.send_message",
    "db.commit"
  ],
  "approved_side_effect_roots": [
    "runtime/",
    "infrastructure/",
    "integrations/",
    "connectors/",
    "scripts/"
  ],
  "admin_required_terms": [
    "admin",
    "control_plane",
    "status",
    "risk",
    "evidence",
    "health"
  ],
  "registry_required_terms": [
    "registry",
    "manifest",
    "capability",
    "policy",
    "guard",
    "action"
  ],
  "canonical_name_groups": [
    [
      "tenant",
      "account",
      "business",
      "workspace"
    ],
    [
      "user",
      "client",
      "customer"
    ],
    [
      "decision",
      "command",
      "action",
      "effect"
    ],
    [
      "memory",
      "state",
      "context",
      "world_model"
    ],
    [
      "payment",
      "billing",
      "invoice",
      "order"
    ]
  ],
  "canonical_name_alias_policy": {
    "tenant": {
      "canonical": "tenant",
      "aliases": [
        "account",
        "business",
        "workspace"
      ],
      "reason": "tenant is the canonical isolation boundary; account/business/workspace are documented product/domain aliases and must not create competing authority."
    },
    "user": {
      "canonical": "user",
      "aliases": [
        "client",
        "customer"
      ],
      "reason": "user is the canonical actor; client/customer are domain-facing aliases and must route through the same user/customer identity model."
    },
    "action": {
      "canonical": "action",
      "aliases": [
        "decision",
        "command",
        "effect"
      ],
      "reason": "action is the executable registry unit; decisions, commands and effects are phases of the same canonical signal/state/decision/policy/guard/execution/verification/evidence/archive flow."
    },
    "state": {
      "canonical": "state",
      "aliases": [
        "memory",
        "context",
        "world_model"
      ],
      "reason": "state is canonical; memory/context/world_model are bounded projections and must not become a second brain."
    },
    "billing": {
      "canonical": "billing",
      "aliases": [
        "payment",
        "invoice",
        "order"
      ],
      "reason": "billing is canonical financial control-plane vocabulary; payment/invoice/order are lifecycle concepts guarded by the same policy/evidence controls."
    }
  }
}
