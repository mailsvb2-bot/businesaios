# BusinesAIOS production environment template.
# This file is intentionally fail-closed. Runtime secrets and DSNs must be injected by the deployment environment.

APP_ENV=prod
ENV=prod
LOG_LEVEL=INFO
TENANT_ID=
BAIOS_DATA_DIR=/var/lib/businesaios/runtime

APP_PROFILE=api
RUN_MODE=telegram
API_HOST=0.0.0.0
API_PORT=8000
HEALTH_HOST=127.0.0.1
TELEGRAM_HEALTH_PORT=8088
EVOLUTION_HEALTH_PORT=8087
EVOLUTION_ENABLED=1

STORAGE_BACKEND=postgres
DATABASE_URL=
POSTGRES_DSN=
POSTGRES_RUNTIME_ENABLED=1
POSTGRES_EVENT_STORE_ENABLED=1
RUN_MIGRATIONS_BEFORE_START=1
POSTGRES_APPLY_MIGRATIONS=1
POSTGRES_LIVE_PROOF_REQUIRED=1
POSTGRES_BACKUP_EVIDENCE_OK=0
POSTGRES_BACKUP_EVIDENCE_PATH=
CONTAINER_RUNTIME_PROOF_REQUIRED=1
CONTAINER_RUNTIME_EVIDENCE_REQUIRED=1
REAL_RUNTIME_BOOT_EVIDENCE_REQUIRED=1
PRODUCTION_BOOT_PROOF_REQUIRED=1
BAIOS_REQUIRE_TRANSITIVE_DEPENDENCY_LOCK=1

TELEGRAM_BOT_TOKEN=
TELEGRAM_USE_WEBHOOK=1
TELEGRAM_WEBHOOK_ENABLED=1
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_HOST=0.0.0.0
TELEGRAM_WEBHOOK_PORT=8080
TELEGRAM_WEBHOOK_AUTO_REGISTER=1
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=0
TELEGRAM_WEBHOOK_MAX_CONNECTIONS=40
TELEGRAM_WEBHOOK_ALLOWED_UPDATES=message,callback_query

CONTROL_PLANE_API_KEY=
API_CONTROL_PLANE_API_KEY_PEPPER=
BUSINESAIOS_API_KEY_STORE_BACKEND=file
BUSINESAIOS_API_KEY_STORE_PATH=/var/lib/businesaios/runtime/api/api_keys.json
API_DOCS_ENABLED=0
API_IDEMPOTENCY_PATH=/var/lib/businesaios/runtime/api/api_idempotency.sqlite3

SECRET_VAULT_BACKEND=postgres
KEY_PROVIDER_BACKEND=postgres
