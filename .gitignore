runtime/platform/support/storage/artifacts/

# Runtime sqlite/state artifacts generated by local services
.runtime/
data/runtime/*.sqlite3
data/runtime/**/*.sqlite3
data/runtime/*.db
data/runtime/**/*.db
data/runtime/*.sqlite
data/runtime/**/*.sqlite

# Runtime mutable state must never be committed
data/**/*.sqlite
data/**/*.sqlite3
data/**/*.db
data/config/
.runtime/
